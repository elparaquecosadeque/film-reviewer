{
  "name": "letterbox-reviews",
  "version": "1.0.0",
  "tasks": {
    "review": "deno run --allow-read --allow-write --allow-run --allow-net --allow-env src/main.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check src/main.ts"
  },
  "compilerOptions": {
    "strict": true
  },
  "fmt": {
    "indentWidth": 2,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "include": ["no-unused-vars", "no-explicit-any", "eqeqeq"]
    }
  },
  "imports": {
    "npm:ollama": "npm:ollama@^0.5.0",
    "jsr:@std/path": "jsr:@std/path@^1.0.0",
    "jsr:@std/dotenv": "jsr:@std/dotenv@^0.224.0"
  }
}
