# TMDB API key — free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key

# Whisper model: tiny | base | small | medium | large-v3 (default, most accurate)
# Use "medium" if large-v3 is too slow on your machine
WHISPER_MODEL=large-v3

# Your spoken language — skip auto-detection for better accuracy (ISO 639-1 code)
# e.g. en, es, fr, de
WHISPER_LANGUAGE=es

# Optional: full path to whisper.exe if pip's Scripts folder isn't on PATH
# Windows example: WHISPER_PATH=C:\Users\YourName\AppData\Roaming\Python\Python312\Scripts\whisper.exe
# WHISPER_PATH=whisper

# Optional: Ollama model override (default: llama3.2)
# OLLAMA_MODEL=llama3.2
